# ─────────────────────────────────────────────────────────────
#  Olympus v1.0.0 — 환경변수 설정 예시
#  복사 후 실제 값으로 채워서 shell 설정에 추가하세요.
#
#  사용법:
#    cp .env.example .env
#    # 값 편집 후:
#    source .env                   # 현재 세션에 적용
#    # 또는 ~/.zshrc / ~/.bashrc에 직접 붙여넣기
# ─────────────────────────────────────────────────────────────

# ┌──────────────────────────────────────────────────────────┐
# │  필수 (Telegram 봇을 사용하는 경우)                       │
# └──────────────────────────────────────────────────────────┘

# Telegram 봇 토큰 (@BotFather에서 발급)
# 발급 방법: Telegram에서 @BotFather 검색 → /newbot → 이름/username 입력 → 토큰 복사
TELEGRAM_BOT_TOKEN=

# 봇 사용을 허용할 Telegram User ID (쉼표로 여러 명 가능)
# User ID 확인: Telegram에서 @userinfobot 검색 → /start → 내 ID 확인
ALLOWED_USERS=

# ┌──────────────────────────────────────────────────────────┐
# │  선택 — Gateway 설정                                      │
# └──────────────────────────────────────────────────────────┘

# Gateway 접근을 위한 API 키 (빈 값이면 인증 없음 — 로컬 전용 시 생략 가능)
OLYMPUS_API_KEY=

# 워커(olympus start)가 접속할 Gateway URL (기본: http://127.0.0.1:8200)
OLYMPUS_GATEWAY_URL=http://127.0.0.1:8200

# ┌──────────────────────────────────────────────────────────┐
# │  선택 — Telegram 보안 설정 (고급)                         │
# └──────────────────────────────────────────────────────────┘

# 관리자 User ID (쉼표 구분). 관리자는 모든 명령 사용 가능
TELEGRAM_ADMIN_USERS=

# 그룹 채팅 허용 정책: allow | deny | allowlist (기본: deny)
TELEGRAM_GROUP_POLICY=deny

# 허용된 그룹 채팅 ID (TELEGRAM_GROUP_POLICY=allowlist일 때만 사용)
TELEGRAM_ALLOWED_GROUPS=

# DM 정책: allow | allowlist (기본: allow)
TELEGRAM_DM_POLICY=allow

# 그룹에서 봇 멘션 필수 여부: true | false (기본: true)
TELEGRAM_REQUIRE_MENTION=true

# 그룹에서 관리자만 명령 허용: true | false (기본: false)
TELEGRAM_GROUP_ADMIN_ONLY=false

# 분당 메시지 수 제한 (기본: 30)
TELEGRAM_RATE_LIMIT=30

# ┌──────────────────────────────────────────────────────────┐
# │  선택 — GeminiAdvisor 설정 (Multi-AI 협업 시)             │
# └──────────────────────────────────────────────────────────┘

# Gemini 모델 오버라이드 (기본: gemini-3-flash-preview)
# OLYMPUS_GEMINI_MODEL=gemini-3-flash-preview

# Gemini 주기적 분석 간격 ms (0=change-driven, 기본값)
# OLYMPUS_GEMINI_REFRESH_MS=0

# 코드 리뷰 전 Gemini 사전 검토 활성화: true | false (기본: false)
# OLYMPUS_GEMINI_PRE_REVIEW=false

# 코드 리뷰 후 Gemini 검토 활성화: true | false (기본: false)
# OLYMPUS_GEMINI_POST_REVIEW=false

# Gemini 분석 타임아웃 ms (기본: 30000)
# OLYMPUS_GEMINI_ANALYSIS_TIMEOUT_MS=30000

# ┌──────────────────────────────────────────────────────────┐
# │  선택 — 워크스페이스 경로                                  │
# └──────────────────────────────────────────────────────────┘

# Olympus가 프로젝트를 찾을 루트 경로 (기본: $HOME)
# OLYMPUS_WORKSPACE_ROOT=/path/to/your/projects
